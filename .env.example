# Client (Vercel build env)
VITE_GAME_SERVER=http://localhost:8000
VITE_GAME_SERVER_PORT=8000

# Set this when you share the app through a public domain or tunnel.
VITE_PUBLIC_APP_ORIGIN=

# Server (Render runtime env)
PORT=8000

# Comma-separated origins allowed to access the app and lobby API.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_API_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional log-only value for the public game server URL.
PUBLIC_GAME_SERVER_ORIGIN=